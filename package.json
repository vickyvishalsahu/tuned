{
  "name": "radio",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "clean": "turbo run clean",
    "clean:deep": "find . -type d \\( -name 'node_modules' -o -name 'dist' -o -name '.turbo' -o -name '.next' \\) -prune -exec rm -rf '{}' +",
    "build:fresh": "pnpm clean:deep && pnpm install && pnpm build",
    "release": "./release",
    "release:dry": "./release --dry-run"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "@radio/backend", "esbuild", "prisma", "sharp", "unrs-resolver"]
  }
}
